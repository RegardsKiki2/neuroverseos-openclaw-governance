{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "index.ts",
    "types.ts",
    "condition-engine.ts",
    "governance-engine.ts",
    "audit-logger.ts",
    "world-bootstrap.ts",
    "drift-monitor.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
